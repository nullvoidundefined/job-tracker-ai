{
    "name": "job-tracker-ai",
    "version": "1.0.0",
    "type": "module",
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "build": "tsc && tsc-alias -p tsconfig.json",
        "dev": "tsx watch src/index.ts",
        "format": "prettier --config prettier.config.bottomlessmargaritas.mjs --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
        "format:check": "prettier --config prettier.config.bottomlessmargaritas.mjs --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
        "lint": "eslint --config eslint.config.bottomlessmargaritas.js .",
        "lint:fix": "eslint --config eslint.config.bottomlessmargaritas.js . --fix",
        "migrate:down": "node-pg-migrate down",
        "migrate:up": "node-pg-migrate up",
        "prepare": "lefthook install || true",
        "start": "node dist/index.js",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:integration": "vitest run integration",
        "test:watch": "vitest",
        "bottomlessmargaritas:format": "prettier --config prettier.config.bottomlessmargaritas.mjs --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
        "bottomlessmargaritas:format:check": "prettier --config prettier.config.bottomlessmargaritas.mjs --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
        "bottomlessmargaritas:lint": "eslint --config eslint.config.bottomlessmargaritas.js .",
        "bottomlessmargaritas:lint:fix": "eslint --config eslint.config.bottomlessmargaritas.js . --fix"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.80.0",
        "@google-cloud/secret-manager": "^6.1.1",
        "bcrypt": "^6.0.0",
        "connect-pg-simple": "^10.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.2.1",
        "express-session": "^1.18.2",
        "helmet": "^8.1.0",
        "node-pg-migrate": "^8.0.4",
        "pg": "^8.18.0",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "tsc-alias": "^1.8.16",
        "typescript": "^5.9.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@babel/eslint-parser": "^7.28.6",
        "@bottomlessmargaritas/claude-architecture-prompts": "^3.0.0",
        "@bottomlessmargaritas/formatting-configs": "^2.1.0",
        "@eslint/eslintrc": "^3.3.4",
        "@trivago/prettier-plugin-sort-imports": "^5.2.2",
        "@types/bcrypt": "^6.0.0",
        "@types/connect-pg-simple": "^7.0.3",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-session": "^1.18.2",
        "@types/node": "^25.3.0",
        "@types/pg": "^8.16.0",
        "@types/supertest": "^6.0.2",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "@vitest/coverage-v8": "^3.2.4",
        "eslint": "^9.39.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-security": "^3.0.0",
        "eslint-plugin-unused-imports": "^4.1.4",
        "globals": "^17.3.0",
        "lefthook": "^2.1.1",
        "nodemon": "^3.1.14",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.8.1",
        "supertest": "^7.0.0",
        "tsx": "^4.21.0",
        "typescript-eslint": "^8.56.1",
        "vitest": "^3.2.4"
    }
}
