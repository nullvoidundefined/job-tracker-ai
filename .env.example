# Allowed CORS origin for the frontend
CORS_ORIGIN=http://localhost:5173

# Database (e.g. Neon, local Postgres). Rotate credentials if ever exposed.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret for express-session cookie signing (use a long random string; never commit real values).
SESSION_SECRET=change-me-to-a-long-random-string
# Set to "true" to verify SSL certs in dev/staging; "false" to allow self-signed in production (not recommended).
# DATABASE_SSL_REJECT_UNAUTHORIZED=

# development | production
NODE_ENV=development

# Server port
PORT=3000

# Rate limiter backing store (e.g. redis://...). Falls back to in-memory with a warning in production.
# RATE_LIMIT_STORAGE_URI=
